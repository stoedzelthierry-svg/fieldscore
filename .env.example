# Environnement FieldScore

# Base de données
DATABASE_URL=postgresql+asyncpg://fieldscore:fieldscore@localhost:5432/fieldscore
POSTGRES_USER=fieldscore
POSTGRES_PASSWORD=fieldscore
POSTGRES_DB=fieldscore

# Application
ENVIRONMENT=development
LOG_LEVEL=info
API_PREFIX=/api/v1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Sécurité (production uniquement)
# SECRET_KEY=change-moi-en-production
# CORS_ORIGINS=http://localhost:3000,https://fieldscore.example.com

# Email (notifications optionnelles)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@fieldscore.example.com

# Géodonnées (optionnel)
# GEOSERVER_URL=http://localhost:8080/geoserver
# RPG_API_URL=https://data.geopf.fr/api
